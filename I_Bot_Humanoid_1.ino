// ---------------- SETUP ----------------
void setup() {
  Serial.begin(9600);
  ESP_BT.begin("humanoid bt");
  Serial.println("Bluetooth Device is Ready to Pair");

  // OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    for (;;);
  }
  display.setRotation(2);
  testdrawbitmap();

  // Pin modes
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  pinMode(in3, OUTPUT);
  pinMode(in4, OUTPUT);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT);

  // ---- SERVO PWM FIX (IMPORTANT) ----
  ESP32PWM::allocateTimer(0);
  ESP32PWM::allocateTimer(1);
  ESP32PWM::allocateTimer(2);
  ESP32PWM::allocateTimer(3);

  motor_2.setPeriodHertz(50);
  motor_3.setPeriodHertz(50);

  motor_2.attach(32);
  motor_3.attach(33);

  motor_2.write(servo2);
  motor_3.write(servo3);
}

// ---------------- LOOP ----------------
void loop() {

  if (ESP_BT.available()) {
    bt_data = ESP_BT.read();
    Serial.println(bt_data);
    Serial.print("Received:"); Serial.println(bt_data);
  }

  // -------- MOVEMENT --------
  if (bt_data == 4) forword();
  else if (bt_data == 3) backword();
  else if (bt_data == 1) turnLeft();
  else if (bt_data == 2) turnRight();
  else if (bt_data == 5 || bt_data == 33) Stop();
  else if (bt_data == 22) dance();

  // -------- LED --------
  else if (bt_data == 61) ledon();
  else if (bt_data == 62) ledoff();

  // -------- SERVO 2 --------
  else if (bt_data == 13) {
    if (servo2 > 0) servo2 -= 1;
    motor_2.write(servo2);
  }
  else if (bt_data == 12) {
    if (servo2 < 180) servo2 += 1;
    motor_2.write(servo2);
  }

  // -------- SERVO 3 --------
  else if (bt_data == 15) {
    if (servo3 > 0) servo3 -= 1;
    motor_3.write(servo3);
  }
  else if (bt_data == 14) {
    if (servo3 < 180) servo3 += 1;
    motor_3.write(servo3);
  }

  // -------- ULTRASONIC (NON-BLOCKING) --------
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH, 25000);
  distance = duration * 0.034 / 2;

  if (bt_data == 40){
display.clearDisplay();

    display.drawBitmap(
    (display.width()  - LOGO_WIDTH ) / 2,
    (display.height() - LOGO_HEIGHT) / 2,
    epd_bitmap_shock, LOGO_WIDTH, LOGO_HEIGHT, 1);
    
  display.display();
  delay(1000);
  
  //second
  display.clearDisplay();
 
